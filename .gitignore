# =====================================================
# GITIGNORE PARA MLOPS4OFP — FASES, VARIANTES Y DVC
# =====================================================

# === EXCEPCIONES CRÍTICAS (Sobrescriben reglas globales) ===
# Forzamos a Git a rastrear la carpeta .dvc (necesario para inicializar)
!.dvc/
# Pero ignoramos estrictamente el archivo de credenciales locales
.dvc/config.local

# === DVC CACHE (NUNCA subir estos directorios) ===
/.dvc/cache/
/.dvc/tmp/

# === ARCHIVOS DE SALIDA GLOBALES NO VERSIONADOS ===
/outputs/
/local_dvc_store/
/local_dvc_store/*

# === RAW DATA (controlado SOLO por DVC) ===
*.csv
# data/raw_merged.csv
# data/raw.csv

# === ENTORNOS Y ARCHIVOS DEL SISTEMA ===
.venv/
__pycache__/
.DS_Store
.idea/
#.vscode/*
*.log

# === DATASETS Y SALIDAS ===
exports/
*.parquet

# === IGNORAR ARTEFACTOS DE VARIANTES ===
executions/*/v*/**/*.parquet
executions/*/v*/**/*.csv
executions/*/v*/**/*.json
executions/*/v*/**/*.html
executions/*/v*/**/figures/
executions/*/v*/**/reports/
.executions

# ⚠️ PERMITIR ARCHIVOS .dvc (son ligeros y necesarios)
!executions/*/v*/*.dvc

# === NOTEBOOKS ANTIGUOS ===
notebooks-old/*

# === SEGURIDAD Y CREDENCIALES ===
.env
.env.local
.env-gfolders
env.md
setup/gdrive_credentials.json
setup/gdrive-credentials.json
client_secrets.json
token.json
gdrive_token.json
dvc_token.json
service_account.json
*.key
*.pem
*.p12

# === APPS Y PIPELINES ===
apps/windows_app/files_output/epoch_processed
apps/windows_app/files_output/queries
apps/temporal_app/epoch_processed
pipeline_lineage.html
03_deploy-api.http
*deploy-api.http